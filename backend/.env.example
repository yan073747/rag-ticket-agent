RAG_AGENT_DATABASE_PATH=backend/data/app.db
RAG_AGENT_UPLOAD_DIR=backend/uploads
RAG_AGENT_CHROMA_DIR=backend/data/chroma

# Optional: enable DeepSeek answer generation for RAG.
# If DEEPSEEK_API_KEY is empty, the app falls back to local source-based answers.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=30
